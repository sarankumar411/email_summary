APP_NAME="Email Context System"
ENVIRONMENT=local
API_V1_PREFIX=/api/v1
SECRET_KEY=replace-with-a-strong-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
ENCRYPTION_KEYS_JSON={"1":"MDAwMDAwMDAwMDAwMDAwMDAwMDAwMDAwMDAwMDAwMDA="}
ACTIVE_ENCRYPTION_KEY_VERSION=1

DATABASE_WRITE_URL=postgresql+asyncpg://email_context:email_context@postgres:5432/email_context
DATABASE_READ_URL=postgresql+asyncpg://email_context:email_context@postgres:5432/email_context
REDIS_URL=redis://:email_context@redis:6379/0
CELERY_BROKER_URL=redis://:email_context@redis:6379/1
CELERY_RESULT_BACKEND=redis://:email_context@redis:6379/2

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
USE_MOCK_GEMINI=true
SUMMARY_CHUNK_THRESHOLD=50
CORS_ALLOW_ORIGINS=["http://localhost:3000","http://localhost:5173"]
